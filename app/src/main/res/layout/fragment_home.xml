<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <data>
    </data>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#F6F7FB"
        tools:context=".fragments.HomeFragment">

        <!-- TITLE -->
        <TextView
            android:id="@+id/titleHome"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="My Notes"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="#222222"
            android:layout_marginTop="20dp"
            android:layout_marginStart="20dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"/>

        <!-- SUBTITLE -->
        <TextView
            android:id="@+id/subTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Organize your thoughts"
            android:textSize="14sp"
            android:textColor="#777777"
            android:layout_marginStart="20dp"
            app:layout_constraintTop_toBottomOf="@id/titleHome"
            app:layout_constraintStart_toStartOf="parent"/>

        <!-- EMPTY STATE IMAGE -->
        <ImageView
            android:id="@+id/emptyNotesImage"
            android:layout_width="220dp"
            android:layout_height="220dp"
            android:src="@drawable/emptybkg"
            android:visibility="gone"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <!-- EMPTY TEXT -->
        <TextView
            android:id="@+id/emptyText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="No notes yet\nTap + to add one"
            android:textAlignment="center"
            android:textSize="16sp"
            android:textColor="#999999"
            android:visibility="gone"
            app:layout_constraintTop_toBottomOf="@id/emptyNotesImage"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <!-- NOTES LIST -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/homeRecyclerView"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:padding="12dp"
            android:clipToPadding="false"
            app:layout_constraintTop_toBottomOf="@id/subTitle"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <!-- FLOATING ACTION BUTTON -->
        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/addNoteFab"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:contentDescription="Add Note"
            android:src="@drawable/baseline_add_24"
            app:backgroundTint="@color/purple"
            app:tint="#FFFFFF"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_margin="20dp"/>

    </androidx.constraintlayout.widget.ConstraintLayout>
</layout>